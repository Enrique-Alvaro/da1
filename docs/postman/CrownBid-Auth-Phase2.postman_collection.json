          "raw": "{{baseUrl}}/api/users/me",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users", "me"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 401\", function () {",
              "  pm.response.to.have.status(401);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Users me - first-login token rejected (401)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessTokenInitial}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/users/me",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users", "me"]
        },
        "description": "Ejecutá después de Login - success first login; token tipo initial_password_change no válido para /me."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 401\", function () {",
