          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"not-an-email\",\n  \"password\": \"secret\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 422\", function () {",
              "  pm.response.to.have.status(422);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Change initial password - success (200)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessTokenInitial}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"currentPassword\": \"{{temporaryPassword}}\",\n  \"newPassword\": \"{{newPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/change-initial-password",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "change-initial-password"]
        },
        "description": "Ejecutá antes Login - success first login para llenar accessTokenInitial."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test(\"JWT access y flags\", function () {",
              "  pm.expect(body.accessToken).to.be.a(\"string\").and.not.empty;",
              "  pm.expect(body.mustChangePassword).to.eql(false);",
              "  pm.expect(body.isFirstLogin).to.eql(false);",
              "  pm.expect(body.user.requiresPasswordChange).to.eql(false);",
              "});",
              "",
              "if (pm.response.code === 200 && body.accessToken) {",
              "  pm.collectionVariables.set(\"accessToken\", body.accessToken);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Change initial password - wrong current password (401)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessTokenInitial}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"currentPassword\": \"wrong-temporary-password\",\n  \"newPassword\": \"{{newPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/change-initial-password",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "change-initial-password"]
        },
        "description": "Usá un token initial válido; contraseña actual incorrecta a propósito."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 401\", function () {",
              "  pm.response.to.have.status(401);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Change initial password - already completed (409)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessTokenInitial}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"currentPassword\": \"{{temporaryPassword}}\",\n  \"newPassword\": \"OtraPassword456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/change-initial-password",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "change-initial-password"]
        },
        "description": "Ejecutá después de \"Change initial password - success\" con el mismo `accessTokenInitial`: la API debe responder 409 (usuario ya completó el cambio)."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 409\", function () {",
              "  pm.response.to.have.status(409);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Login - success after password change (200)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{loginEmail}}\",\n  \"password\": \"{{newPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        },
        "description": "Tras completar el cambio inicial con newPassword."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test(\"sin primer login\", function () {",
              "  pm.expect(body.mustChangePassword).to.eql(false);",
              "  pm.expect(body.isFirstLogin).to.eql(false);",
              "  pm.expect(body.user.requiresPasswordChange).to.eql(false);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth logout (204)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/logout",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "logout"]
        },
        "description": "Bearer tipo **access**. Revoca el `jti` en servidor. Ejecutá tras tener `accessToken` (login definitivo o change-password)."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 204\", function () {",
              "  pm.response.to.have.status(204);",
              "});",
              "",
              "pm.test(\"sin cuerpo\", function () {",
              "  pm.expect(pm.response.text()).to.eql(\"\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Users me - success (200)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/users/me",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users", "me"]
        },
        "description": "Usá `accessToken` tras login con contraseña definitiva o tras change-initial-password (variable `accessToken`)."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test(\"perfil público sin hash\", function () {",
              "  pm.expect(body).to.not.have.property(\"password_hash\");",
              "  pm.expect(body).to.not.have.property(\"passwordHash\");",
              "  pm.expect(body.id).to.be.a(\"string\");",
              "});"
            ]
          }
        }
      ]
    },
