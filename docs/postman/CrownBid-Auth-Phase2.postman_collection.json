    {
      "name": "Register - success (201)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Nasser\",\n  \"lastName\": \"El Bacha\",\n  \"email\": \"{{registerEmail}}\",\n  \"documentNumber\": \"{{registerDocumentNumber}}\",\n  \"address\": \"Av. Siempre Viva 123\",\n  \"countryId\": 1,\n  \"documentFrontImageBase64\": null,\n  \"documentBackImageBase64\": null\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "register"]
        },
        "description": "`countryId` debe existir en `paises.numero`. Ajustá `registerDocumentNumber` si el documento ya está usado."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 201\", function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test(\"Respuesta Auth-2: message, user, emailSentTo\", function () {",
              "  pm.expect(body).to.have.property(\"message\");",
              "  pm.expect(body).to.have.property(\"emailSentTo\");",
              "  pm.expect(body).to.have.property(\"user\");",
              "  pm.expect(body.emailSentTo).to.eql(body.user.email);",
              "});",
              "",
              "pm.test(\"No expone password ni hash\", function () {",
              "  pm.expect(body).to.not.have.property(\"temporaryPassword\");",
              "  pm.expect(body).to.not.have.property(\"passwordHash\");",
              "  pm.expect(body.user).to.not.have.property(\"passwordHash\");",
              "  pm.expect(body.user).to.not.have.property(\"password_hash\");",
              "  pm.expect(body.user).to.not.have.property(\"requiresPasswordChange\");",
              "});",
              "",
              "pm.test(\"user id entero y perfil español\", function () {",
              "  pm.expect(body.user.id).to.be.a(\"number\");",
              "  pm.expect(body.user).to.have.property(\"documentNumber\");",
              "  pm.expect(body.user).to.have.property(\"fullName\");",
              "  pm.expect(body.user).to.have.property(\"email\");",
              "  pm.expect(body.user).to.have.property(\"status\");",
              "  pm.expect(body.user).to.have.property(\"admitted\");",
              "  pm.expect(body.user).to.have.property(\"category\");",
              "});"
            ]
          }
        }
      ]
    },
