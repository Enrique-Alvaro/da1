      ]
    },
    {
      "name": "Register - invalid email (422)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Nasser\",\n  \"lastName\": \"El Bacha\",\n  \"email\": \"not-an-email\",\n  \"documentId\": \"12345678\",\n  \"address\": \"Av. Siempre Viva 123\",\n  \"country\": \"AR\",\n  \"documentFrontImageUrl\": \"https://example.com/dni-front.jpg\",\n  \"documentBackImageUrl\": \"https://example.com/dni-back.jpg\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "register"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 422\", function () {",
              "  pm.response.to.have.status(422);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Login - success first login (200)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{loginEmail}}\",\n  \"password\": \"{{temporaryPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        },
        "description": "Antes de ejecutar: definí `temporaryPassword` (correo o logs dev). Esperado: mustChangePassword e isFirstLogin true."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test(\"accessToken y primer login\", function () {",
              "  pm.expect(body.accessToken).to.be.a(\"string\").and.not.empty;",
              "  pm.expect(body.mustChangePassword).to.eql(true);",
              "  pm.expect(body.isFirstLogin).to.eql(true);",
              "  pm.expect(body.user.requiresPasswordChange).to.eql(true);",
              "});",
              "",
              "if (pm.response.code === 200 && body.accessToken) {",
              "  pm.collectionVariables.set(\"accessTokenInitial\", body.accessToken);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Login - invalid credentials (401)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{loginEmail}}\",\n  \"password\": \"wrong-password-xyz\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 401\", function () {",
              "  pm.response.to.have.status(401);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test(\"mensaje genérico\", function () {",
              "  pm.expect(body.message).to.include(\"Credenciales\");",
              "});"
            ]
          }
        }
      ]
    },
