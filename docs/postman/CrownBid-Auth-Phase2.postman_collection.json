      "name": "Change initial password - success (200)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessTokenInitial}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"currentPassword\": \"{{temporaryPassword}}\",\n  \"newPassword\": \"{{newPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/change-initial-password",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "change-initial-password"]
        },
        "description": "Bearer token tipo `initial_password_change` (variable `accessTokenInitial`)."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test(\"JWT access y flags en raíz\", function () {",
              "  pm.expect(body.accessToken).to.be.a(\"string\").and.not.empty;",
              "  pm.expect(body.mustChangePassword).to.eql(false);",
              "  pm.expect(body.isFirstLogin).to.eql(false);",
              "  pm.expect(body.user).to.not.have.property(\"requiresPasswordChange\");",
              "});",
              "",
              "pm.test(\"JWT type access\", function () {",
              "  const parts = body.accessToken.split(\".\");",
              "  const payload = JSON.parse(atob(parts[1].replace(/-/g, \"+\").replace(/_/g, \"/\")));",
              "  pm.expect(payload.type).to.eql(\"access\");",
              "});",
              "",
              "if (pm.response.code === 200 && body.accessToken) {",
              "  pm.collectionVariables.set(\"accessToken\", body.accessToken);",
              "}"
            ]
          }
        }
      ]
    },
