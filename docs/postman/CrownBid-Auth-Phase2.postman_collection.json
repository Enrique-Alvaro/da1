    {
      "name": "Domain tables (esquema SQL)",
      "description": "Rutas bajo `/api`. Requieren **Authorization: Bearer {{accessToken}}** (token tipo `access`, no el de primer login).\n\n**Paises:** `paisNumero` para lectura; `paisNumeroNuevo` para alta/edición/baja de prueba (evitar borrar el país usado por clientes si hay FK).\n\n**Sectores:** `responsableSector` opcional debe existir en `empleados` si se envía.",
      "item": [
        {
          "name": "Paises - GET list (200)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/paises",
              "host": ["{{baseUrl}}"],
              "path": ["api", "paises"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test(\"items array\", function () {",
                  "  pm.expect(body).to.have.property(\"items\");",
                  "  pm.expect(body.items).to.be.an(\"array\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Paises - GET by id (200)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/paises/{{paisNumero}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "paises", "{{paisNumero}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test(\"tiene numero y nombre\", function () {",
                  "  pm.expect(body).to.have.property(\"numero\");",
                  "  pm.expect(body).to.have.property(\"nombre\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Paises - POST create (201)",
          "request": {
