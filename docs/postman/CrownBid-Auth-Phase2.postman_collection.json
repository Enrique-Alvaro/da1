    "name": "CrownBid Auth Phase 2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Coleccion para validar la base de API y el registro de usuario (Phase 2)."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "registerEmail",
      "value": "nasser.phase2.postman@example.com"
    }
  ],
  "item": [
    {
      "name": "Health - API",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Health - DB",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/health/db",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "health",
            "db"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 200 o 503\", function () {",
              "  pm.expect([200, 503]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Register - success (201)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Nasser\",\n  \"lastName\": \"El Bacha\",\n  \"email\": \"{{registerEmail}}\",\n  \"documentId\": \"12345678\",\n  \"address\": \"Av. Siempre Viva 123\",\n  \"country\": \"AR\",\n  \"documentFrontImageUrl\": \"https://example.com/dni-front.jpg\",\n  \"documentBackImageUrl\": \"https://example.com/dni-back.jpg\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 201\", function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test(\"No expone password ni hash\", function () {",
              "  pm.expect(body).to.not.have.property(\"temporaryPassword\");",
              "  pm.expect(body).to.not.have.property(\"passwordHash\");",
              "  pm.expect(body.user).to.not.have.property(\"passwordHash\");",
              "  pm.expect(body.user).to.not.have.property(\"password_hash\");",
              "});",
              "",
              "pm.test(\"requiresPasswordChange true\", function () {",
              "  pm.expect(body.user.requiresPasswordChange).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
