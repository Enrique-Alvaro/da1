    {
      "name": "Login - success first login (200)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{loginEmail}}\",\n  \"password\": \"{{temporaryPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        },
        "description": "Completá `temporaryPassword` desde el correo o logs dev. Flags **solo** en raíz: mustChangePassword / isFirstLogin. JWT `sub` = id persona (string numérico)."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test(\"accessToken y primer login (sin flags en user)\", function () {",
              "  pm.expect(body.accessToken).to.be.a(\"string\").and.not.empty;",
              "  pm.expect(body.mustChangePassword).to.eql(true);",
              "  pm.expect(body.isFirstLogin).to.eql(true);",
              "  pm.expect(body.user).to.not.have.property(\"requiresPasswordChange\");",
              "});",
              "",
              "pm.test(\"JWT sub numérico\", function () {",
              "  const parts = body.accessToken.split(\".\");",
              "  const payload = JSON.parse(atob(parts[1].replace(/-/g, \"+\").replace(/_/g, \"/\")));",
              "  pm.expect(/^[0-9]+$/.test(payload.sub)).to.be.true;",
              "  pm.expect(payload.type).to.eql(\"initial_password_change\");",
              "});",
              "",
              "if (pm.response.code === 200 && body.accessToken) {",
              "  pm.collectionVariables.set(\"accessTokenInitial\", body.accessToken);",
              "}"
            ]
          }
        }
      ]
    },
