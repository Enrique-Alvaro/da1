# CrownBid API — copy to .env (never commit .env)

NODE_ENV=development
PORT=3000

# Required for API startup (Phase 1): ADO-style connection string for mssql
# Use ONE of the following variable names (same value):
SQLSERVER_CONNECTION_STRING=Server=localhost,1433;Database=CrownBid;User Id=sa;Password=CHANGE_ME;Encrypt=true;TrustServerCertificate=true
# SQL_SERVER_CONNECTION_STRING=...

# Legacy alias — optional if one of the above is set
# DATABASE_URL=

# Phase 2+ Auth (optional until implemented)
# JWT_SECRET=
# JWT_EXPIRES_IN=15m
# BCRYPT_SALT_ROUNDS=12

# Phase 2+ Email (required in production for POST /api/auth/register)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com
# Use port 465 with implicit TLS or 587 with STARTTLS (see nodemailer docs).

# Phase 2+ deep links
# FRONTEND_URL=https://app.example.com
