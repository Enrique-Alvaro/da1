# CrownBid API — copiar a .env y completar (no commitear .env)
NODE_ENV=development
PORT=3000

# SQL Server — cadena estilo ADO/ODBC (no usar prefijo jdbc:)
# SQL auth:
# DATABASE_URL=Server=localhost,1433;Database=CrownBid;User Id=sa;Password=TU_CLAVE;Encrypt=true;TrustServerCertificate=true
# Azure / certificados firmados: quitar TrustServerCertificate o usar Encrypt=strict según doc Microsoft

# JWT (ejemplo)
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
